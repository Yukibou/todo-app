<div class="mt-6 space-y-2 text-center text-sm text-gray-500">
  <%- if controller_name != 'sessions' %>
    <p><%= link_to "ログインはこちら", new_session_path(resource_name), class: "text-indigo-600 hover:text-indigo-800 font-medium" %></p>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <p><%= link_to "アカウント新規登録", new_registration_path(resource_name), class: "text-indigo-600 hover:text-indigo-800 font-medium" %></p>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <p><%= link_to "パスワードをお忘れですか？", new_password_path(resource_name), class: "text-indigo-600 hover:text-indigo-800 font-medium" %></p>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <p><%= link_to "確認メールが届いていない方", new_confirmation_path(resource_name), class: "text-indigo-600 hover:text-indigo-800 font-medium" %></p>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <p><%= link_to "アカウントロック解除メールが届いていない方", new_unlock_path(resource_name), class: "text-indigo-600 hover:text-indigo-800 font-medium" %></p>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <p><%= button_to "#{OmniAuth::Utils.camelize(provider)} でログイン", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "text-indigo-600 hover:text-indigo-800 font-medium" %></p>
    <% end %>
  <% end %>
</div>
